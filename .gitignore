.DS_Store
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.idea/
.vscode/

# run outputs — track only canonical reference artifacts. Keep
# multi-GB checkpoints, per-job Slurm logs, and bulky run scratch
# out of the repo.

# Top-level (canonical full-pipeline results)
/results/*
!/results/.gitkeep
!/results/RESULTS.md
!/results/sample_efficiency.png
!/results/surrogate_results.json
!/results/surrogate_ablation.csv
!/results/ct_known_operator_metrics.json
!/results/ct_known_operator_eval.json
!/results/ct_fully_connected_metrics.json
!/results/ct_fully_connected_eval.json
!/results/run_all.log
!/results/run_all_steps.csv

# GPU-experiments sample-efficiency sweeps (kept for paper figures)
/gpu_experiments/results/*
!/gpu_experiments/results/.gitkeep
!/gpu_experiments/results/sample_efficiency_128/
!/gpu_experiments/results/sample_efficiency_128/**
!/gpu_experiments/results/sample_efficiency_256/
!/gpu_experiments/results/sample_efficiency_256/**

# Slurm output directory: must exist *before* sbatch redirects stdout
# (otherwise jobs fail at 0 s with no .out / .err written). Keep the
# directory itself tracked, but not its per-job *.out / *.err files.
!/gpu_experiments/results/slurm/
!/gpu_experiments/results/slurm/.gitkeep
/gpu_experiments/results/slurm/*.out
/gpu_experiments/results/slurm/*.err

# Re-exclude OS junk inside any allow-listed result subdirectory.
/results/**/.DS_Store
/gpu_experiments/results/**/.DS_Store

/.archive/
