.DS_Store
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.idea/
.vscode/

# run outputs — track the canonical reference artifacts but not the
# heavy/ephemeral pieces (multi-GB checkpoints, per-job slurm logs).
/results/*
!/results/.gitkeep
!/results/RESULTS.md
!/results/sample_efficiency.png
!/results/surrogate_results.json
!/results/surrogate_ablation.csv
!/results/ct_known_operator_metrics.json
!/results/ct_known_operator_eval.json
!/results/ct_fully_connected_metrics.json
!/results/ct_fully_connected_eval.json
!/results/run_all.log
!/results/run_all_steps.csv
!/results/sample_efficiency_128/
!/results/sample_efficiency_128/**
!/results/sample_efficiency_256/
!/results/sample_efficiency_256/**
# Re-exclude OS junk inside the allow-listed result subdirectories.
/results/**/.DS_Store
/.archive/
